# HireView — environment variables
# Copy this file to .env and fill in values as needed.

# --- Data ---
# Leave BOTH blank for local dev (uses a local SQLite file at data/jobs.db).
# In production, set both to use Turso (cloud SQLite). Create a DB with:
#   turso db create hireview && turso db show hireview --url && turso db tokens create hireview
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Web ---
# Comma-separated origins allowed to call the API (your deployed frontend).
# Defaults to localhost for dev if unset.
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Logging ---
LOG_LEVEL=INFO

# --- Adzuna (optional) ---
# General job-board results on top of Greenhouse/Lever/Ashby. Also enterable in the UI.
# Free tier: 250 requests/month. Sign up at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
