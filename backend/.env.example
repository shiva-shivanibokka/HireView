# ── AutoApply Job Agent — API Keys ───────────────────────────────────────────
# Copy this file to .env and fill in all values before running the app.

# Anthropic API key — needed for resume generation, cover letter, JD parsing
# Get yours at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Adzuna API — needed for broad job search results beyond the 40 hardcoded companies
# Free tier: 250 requests/month. Sign up at: developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# GitHub Personal Access Token — needed for project matching from your GitHub profile
# Without this, GitHub rate-limits to 60 req/hour and fails after ~5 repos
# Generate one at: github.com/settings/tokens (only needs public_repo read scope)
GITHUB_TOKEN=
