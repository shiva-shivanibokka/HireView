# Copy this to .env and fill in your values

# Required — Anthropic API key for resume generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Adzuna API (free at developer.adzuna.com, 250 req/month)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional — GitHub token for faster GitHub project fetching (avoids rate limits)
GITHUB_TOKEN=
